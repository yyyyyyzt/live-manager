# Upload server listen config
PORT=3071
HOST=127.0.0.1

# Storage provider: cos | custom | oss
STORAGE_PROVIDER=cos

# COS provider config
COS_SECRET_ID=
COS_SECRET_KEY=
COS_BUCKET=
COS_REGION=
COS_CDN_DOMAIN=
COS_PATH_PREFIX=

# OSS provider config
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_BUCKET=
OSS_ENDPOINT=
OSS_PATH_PREFIX=

# Custom provider config
CUSTOM_UPLOAD_URL=
CUSTOM_ACCESS_DOMAIN=
CUSTOM_UPLOAD_FIELD=file
CUSTOM_RESPONSE_URL_FIELD=data.url
CUSTOM_AUTH_HEADER=
CUSTOM_PATH_PREFIX=
